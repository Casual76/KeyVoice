<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Audio Level Visualizer (shown during recording) -->
        <com.keyvoice.app.ui.AudioLevelView
            android:id="@+id/audio_level_view"
            android:layout_width="80dp"
            android:layout_height="32dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            tools:visibility="gone" />

        <!-- Processing Spinner (shown during API calls) -->
        <ProgressBar
            android:id="@+id/progress_spinner"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginBottom="8dp"
            android:indeterminateTint="@color/primary"
            android:visibility="gone"
            tools:visibility="gone" />

        <!-- Microphone Button -->
        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_mic_idle"
            android:src="@drawable/ic_mic"
            android:scaleType="center"
            android:elevation="6dp"
            android:contentDescription="@string/cd_microphone"
            android:stateListAnimator="@null" />

        <!-- Status Text -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            tools:text="Trascrizione in corso…" />

        <!-- Countdown Timer -->
        <TextView
            android:id="@+id/tv_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="@color/warning"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone"
            tools:text="10 secondi rimanenti" />

        <!-- Idle Hint -->
        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/state_idle"
            android:textSize="13sp"
            android:textColor="@color/text_hint" />

        <!-- Error Display -->
        <LinearLayout
            android:id="@+id/error_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_warning"
                android:layout_marginEnd="4dp"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tv_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/error"
                tools:text="Connessione assente" />
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom Bar -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:background="@color/keyboard_bottom_bar">

        <!-- Spacer left -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Undo Button (shown after text insertion) -->
        <ImageButton
            android:id="@+id/btn_undo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_ripple"
            android:src="@drawable/ic_undo"
            android:scaleType="center"
            android:contentDescription="@string/cd_undo"
            android:padding="10dp"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Spacer right -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Settings Button -->
        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_ripple"
            android:src="@drawable/ic_settings"
            android:scaleType="center"
            android:contentDescription="@string/cd_settings"
            android:padding="10dp" />

    </LinearLayout>

</LinearLayout>
