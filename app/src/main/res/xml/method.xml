<?xml version="1.0" encoding="utf-8"?>
<input-method xmlns:android="http://schemas.android.com/apk/res/android"
    android:settingsActivity="com.keyvoice.app.MainSetupActivity"
    android:icon="@drawable/ic_mic"
    android:supportsSwitchingToNextInputMethod="true">

    <subtype
        android:label="@string/subtype_italian"
        android:imeSubtypeLocale="it"
        android:languageTag="it"
        android:imeSubtypeMode="voice"
        android:isAuxiliary="true" />

    <subtype
        android:label="@string/subtype_english"
        android:imeSubtypeLocale="en"
        android:languageTag="en"
        android:imeSubtypeMode="voice"
        android:isAuxiliary="true" />

</input-method>
